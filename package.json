{
  "name": "vikingapp",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev:server": "dotenv -e .env -- npm run dev --workspace server",
    "dev:client": "dotenv -e .env -- npm run dev --workspace client",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "build:server": "npm run build --workspace server",
    "build:client": "npm run build --workspace client",
    "build": "npm run build:server && npm run build:client",
    "test:client": "npm run test --workspace client",
    "test:server": "npm run test --workspace server",
    "test:i18n": "npm run test:i18n --workspace client",
    "test": "npm run test:server && npm run test:i18n && npm run test:client",
    "typecheck": "npm run typecheck --workspace client",
    "seed:test": "node scripts/seedTestScenario.js",
    "snapshots:playwright": "playwright test -c playwright.config.ts"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "playwright": "^1.56.1"
  }
}
